# =============================================================================
# Autonomous Agent Platform — Environment Configuration
# =============================================================================
# Copy this file to .env and fill in your values.

# -----------------------------------------------------------------------------
# LLM Configuration
# -----------------------------------------------------------------------------
# For Anthropic directly:
ANTHROPIC_API_KEY=sk-ant-xxxxxxxxxxxxxxxxxxxxx
ANTHROPIC_MODEL=claude-sonnet-4-20250514

# For OpenRouter (Anthropic-compatible):
# ANTHROPIC_API_KEY=sk-or-v1-your-openrouter-key
# ANTHROPIC_BASE_URL=https://openrouter.ai/api
# ANTHROPIC_MODEL=anthropic/claude-sonnet-4.6
LLM_MAX_TOKENS=2048

# -----------------------------------------------------------------------------
# Embedding Configuration
# -----------------------------------------------------------------------------
OPENAI_API_KEY=sk-xxxxxxxxxxxxxxxxxxxxx
OPENAI_BASE_URL=https://aiapiv2.pekpik.com/v1
EMBEDDING_MODEL=text-embedding-3-small
EMBEDDING_DIMENSIONS=1536

# -----------------------------------------------------------------------------
# Alternative LLM Providers (Pekpik API)
# -----------------------------------------------------------------------------
# DeepSeek
DEEPSEEK_API_KEY=sk-xxxxxxxxxxxxxxxxxxxxx
DEEPSEEK_BASE_URL=https://aiapiv2.pekpik.com/v1
DEEPSEEK_MODEL=deepseek-chat

# Gemini
GEMINI_API_KEY=sk-xxxxxxxxxxxxxxxxxxxxx
GEMINI_BASE_URL=https://aiapiv2.pekpik.com/v1
GEMINI_MODEL=gemini-2.5-flash

# Kimi
KIMI_API_KEY=sk-xxxxxxxxxxxxxxxxxxxxx
KIMI_BASE_URL=https://aiapiv2.pekpik.com/v1
KIMI_MODEL=kimi-k2.5

# Qwen
QWEN_API_KEY=sk-xxxxxxxxxxxxxxxxxxxxx
QWEN_BASE_URL=https://aiapiv2.pekpik.com/v1
QWEN_MODEL=qwen/qwen3.6-27b

# NVIDIA
NVIDIA_API_KEY=sk-xxxxxxxxxxxxxxxxxxxxx
NVIDIA_BASE_URL=https://aiapiv2.pekpik.com/v1
NVIDIA_MODEL=nvidia/nemotron-3-nano-omni-30b-a3b-reasoning:free

# -----------------------------------------------------------------------------
# PostgreSQL Database
# -----------------------------------------------------------------------------
POSTGRES_HOST=localhost
POSTGRES_PORT=5432
POSTGRES_DB=agent_platform
POSTGRES_USER=agent
POSTGRES_PASSWORD=agent_secret_password_change_me
DATABASE_URL=postgresql+asyncpg://agent:agent_secret_password_change_me@localhost:5432/agent_platform

# -----------------------------------------------------------------------------
# Qdrant Vector Database
# -----------------------------------------------------------------------------
QDRANT_URL=http://localhost:6333
QDRANT_API_KEY=

# -----------------------------------------------------------------------------
# Redis Cache
# -----------------------------------------------------------------------------
REDIS_URL=redis://localhost:6379/0

# -----------------------------------------------------------------------------
# Web Search (Tavily)
# -----------------------------------------------------------------------------
TAVILY_API_KEY=tvly-xxxxxxxxxxxxxxxxxxxxx

# -----------------------------------------------------------------------------
# API Security
# -----------------------------------------------------------------------------
JWT_SECRET_KEY=your-super-secret-jwt-key-change-me-in-production
JWT_ALGORITHM=HS256
JWT_EXPIRATION_MINUTES=60
API_KEY_HEADER=X-API-Key

# -----------------------------------------------------------------------------
# Safety & Limits
# -----------------------------------------------------------------------------
MAX_EXECUTION_TIME_SECONDS=300
MAX_MEMORY_TOKENS=128000
SANDBOX_ENABLED=true
MAX_ITERATIONS=50

# -----------------------------------------------------------------------------
# Logging
# -----------------------------------------------------------------------------
LOG_LEVEL=INFO
LOG_FORMAT=json

# -----------------------------------------------------------------------------
# CLI Configuration
# -----------------------------------------------------------------------------
MODELX_API_URL=http://localhost:8000
MODELX_API_KEY=your-modelx-api-key
